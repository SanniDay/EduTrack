@{
    ViewData["Title"] = "Access Denied";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Access Denied</title>

</head>

<body>
    <div class="d-flex align-items-center justify-content-center vh-50">
        <div class="container text-center">
            <div class="card p-5">

                <div class="mb-4">
                    <h1 class="display-1 text-danger fw-bold">403</h1>
                    <h2 class="fw-semibold">Access Denied</h2>
                    <p class="text-muted mt-3">
                        Sorry, you do not have permission to access this page.
                        Please contact the administrator if you believe this is a mistake.
                    </p>
                </div>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                        Back to Home
                    </a>
                </div>

            </div>
        </div>
    </div>


</body>
</html>