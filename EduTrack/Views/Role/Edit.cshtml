@model EduTrack.Models.Role

@{
    ViewData["Title"] = "Edit Role";
}

<h2>Edit Role</h2>

<form asp-action="Edit" method="post" class="form-horizontal">
    <div asp-validation-summary="All" class="text-danger"></div>

    <input asp-for="Role_Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Role_Name" class="form-label"></label>
        <input asp-for="Role_Name" class="form-control" />
        <span asp-validation-for="Role_Name" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>

    <div class="mt-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>
