@model EduTrack.Models.Role

@{
    ViewData["Title"] = "Delete Role";
}

<h2>Delete Role</h2>

<div>
    <h4>Are you sure you want to delete this role?</h4>

    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Role_Id</dd>

        <dt class="col-sm-2">Role Name</dt>
        <dd class="col-sm-10">@Model.Role_Name</dd>

        <dt class="col-sm-2">Created Date</dt>
        <dd class="col-sm-10">@Model.Created_Date.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Role_Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
